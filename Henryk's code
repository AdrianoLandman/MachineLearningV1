def gradient_descent(t, data, alpha=0.01, num_iterations=1000):
    w0 = 0.0
    w1 = 0.0

    for _ in range(num_iterations):
        predictions = w0 + w1 * t
        errors = predictions - data

        dw0 = 2 * np.sum(errors)
        dw1 = 2 * np.sum(errors * t)

        w0 -= alpha * dw0
        w1 -= alpha * dw1

    return w0, w1

w0x, w1x = gradient_descent(T, P[:, 0])
w0y, w1y = gradient_descent(T, P[:, 1])
w0z, w1z = gradient_descent(T, P[:, 2])

def compute_error(w0, w1, t, data):
    predictions = w0 + w1 * t
    return np.sum((predictions - data) ** 2)

