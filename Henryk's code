#_______________Constant acceleration_____________

# px(t)=w0x + w1x * t + w2x * t**2
# py(t)=w0y + w1y * t + w2y * t**2
# pz(t)=w0z + w1z * t + w2z * t**2

def gradient_descent_quad(t, data, alpha=0.0001, num_iterations=2000):

    wa = 0.0
    wb = 0.0
    wc = 0.0

    for _ in range(num_iterations):

        predictions = wa + wb * t + wc *(t**2)
        errors = predictions - data

        da0 = 2*np.sum(errors)
        db1 = 2*np.sum(errors*t)
        dc2 = 2*np.sum(errors*(t**2))

        wa -= alpha*da0
        wb -= alpha*db1
        wc -= alpha*dc2

    return wa, wb, wc


